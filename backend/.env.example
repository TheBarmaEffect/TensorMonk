# ─── Required ───────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here    # Get free key at console.groq.com

# ─── Optional: Web Search Grounding ────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here # Falls back to DuckDuckGo if unset

# ─── Optional: Production Persistence ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0      # AsyncRedisSaver for checkpointing
SESSION_DIR=data/sessions               # JSON session persistence directory

# ─── Optional: Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_RPM=60                       # Requests per minute per IP
RATE_LIMIT_BURST=10                     # Burst capacity for token bucket

# ─── Optional: Server Config ──────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
